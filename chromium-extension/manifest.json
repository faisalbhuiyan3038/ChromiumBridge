{
  "manifest_version": 3,
  "name": "ChromeBridge Companion",
  "version": "1.0.0",
  "description": "Companion extension for ChromeBridge — handles cookie injection and session return.",

  "permissions": [
    "cookies",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/receiver.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/return-button.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["cookies.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
